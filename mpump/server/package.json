    "@ffmpeg/util": "^0.12.2",
    "mp4-muxer": "^5.2.2",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/webmidi": "^2.1.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.5.1",
    "@vitest/coverage-v8": "^4.1.2",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
